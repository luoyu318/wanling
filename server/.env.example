# 服务端会自动加载同目录下的 .env 文件
# 如果 .env 不存在则静默跳过，依赖环境变量

# 服务端口
SERVER_PORT=18008

# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=          # 必填
DB_NAME=wanling
DB_SSLMODE=disable

# Redis 配置（暂未使用）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 密钥（必填，不要使用默认值）
JWT_SECRET=

# 文件存储路径
STORAGE_PATH=./uploads

# CORS 允许的来源（逗号分隔，* 表示全部允许）
CORS_ALLOWED_ORIGINS=*
