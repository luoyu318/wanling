# 部署目标配置。复制为 .env.deploy 后改值。**不入 git**。
# 复制命令：cp server/.env.deploy.example server/.env.deploy

# SSH 目标（用户@主机）。需要免密登录（~/.ssh/id_rsa 已加入远程 authorized_keys）。
REMOTE_HOST=root@IP

# 远程部署根目录。binary 会放到 $REMOTE_PATH/bin/wanling-server
REMOTE_PATH=/usr/local/wanling

# systemd 服务名（重启用）
SERVICE_NAME=wanling-server

# 可选：发布后 HTTP 健康检查 URL（curl 失败只 warn 不 fail）
HEALTH_URL=http://localhost/health
