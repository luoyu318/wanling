# ═══════════════════════════════════════════════════════
# Wanling Docker Compose 环境变量
# 用法：cp .env.example.docker .env && 填值
# ═══════════════════════════════════════════════════════

# ─── Compose 文件选择（控制用 prod 还是 dev）───
# 启动时只需 docker compose up -d（不需要 -f 参数）
# 切换模式：注释/取消注释对应行
COMPOSE_PATH_SEPARATOR=:
COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
# 开发模式用这行（注释上一行，取消注释下面这行）：
# COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# ─── 数据库 ───
POSTGRES_USER=wanling
# 必填。生成强密码：openssl rand -hex 32（输出 64 位 hex）
POSTGRES_PASSWORD=
POSTGRES_DB=wanling

# ─── JWT ───
# 必填。生成：openssl rand -hex 32
# 注意：改 JWT_SECRET 会让所有已登录用户 token 失效
JWT_SECRET=

# ─── CORS ───
# prod 限制为具体域名（如 https://chat.example.com）
# dev 默认 *（dev override 会强制覆盖为 *）
CORS_ALLOWED_ORIGINS=*

# ─── host 暴露端口（容器内端口固定，host 端口可调避免冲突）───
# host 上已有服务占用某个端口时改这里
SERVER_HOST_PORT=18008
# 下面两个仅 dev 模式暴露给 host 调试（prod 不暴露 PG/Redis）
DB_HOST_PORT=6333
REDIS_HOST_PORT=6379
